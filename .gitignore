node_modules/
dist/
# Ship the compiled MCP server with the plugin: the plugin's .mcp.json runs
# packages/mcp/dist/server.js, so fresh/offline (Windows) installs must not need a build.
!packages/core/dist/
!packages/core/dist/**
!packages/mcp/dist/
!packages/mcp/dist/**
coverage/
*.log
*.tsbuildinfo
*.ppt
*.pptx
.DS_Store
.vitest-cache/
.turbo/
.idea/
.vscode/
# Personal, machine-local Claude settings only — team-shared .claude/settings.json IS committed
.claude/settings.local.json
.claude/*.local.json
.claude/*.local.md
# Local-only maintenance skills (not shipped with the plugin)
.claude/skills/

# superpowers brainstorm session files
.superpowers/

# hook sidecar state (project-scoped connection/uncommitted-measures registry)
.pbi-agent-kit/

# The bank-approved win32-arm64 Microsoft Power BI modeling MCP is INTENTIONALLY
# committed under vendor/powerbi-modeling-mcp/ (with its LICENSE) so offline Windows
# installs need no runtime download. x86-64 machines supply their own build.

# Generated release artifacts (zip, checksums, SBOM, test evidence) — produced by
# `pnpm release`, never committed.
release-artifacts/

# Internal AA CoE dev docs — kept LOCAL, not shipped to the bank.
docs/system-improvements.md
docs/workflows/
